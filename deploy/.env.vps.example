# Live Dashboard VPS config
HOST_PORT=3000

# token:device_id:device_name:platform
DEVICE_TOKEN_1=replace_me_token_1:pc-1:PC 1:windows
DEVICE_TOKEN_2=replace_me_token_2:pc-2:PC 2:windows
DEVICE_TOKEN_3=replace_me_token_3:android-1:Android 1:android
DEVICE_TOKEN_4=replace_me_token_4:android-2:Android 2:android

# Generate with: openssl rand -hex 32
HASH_SECRET=replace_me_with_a_random_secret

# Optional: client enrollment secret for requesting/registering tokens
ENROLL_SECRET=

# Admin secret for /admin approval backend
ADMIN_SECRET=

DISPLAY_NAME=Monika
SITE_TITLE=Monika Now
SITE_DESC=What is Monika doing right now?
SITE_FAVICON=/favicon.ico
