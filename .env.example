# Device tokens: format is token:device_id:device_name:platform
DEVICE_TOKEN_1=changeme_token1:pc-1:PC 1:windows
DEVICE_TOKEN_2=changeme_token2:pc-2:PC 2:windows
DEVICE_TOKEN_3=changeme_token3:android-1:Android 1:android
DEVICE_TOKEN_4=changeme_token4:android-2:Android 2:android

# HMAC secret for hashing window_title (used for dedup, prevents rainbow table attacks)
# Generate with: openssl rand -hex 32
HASH_SECRET=changeme_generate_a_random_secret

# Optional enrollment secret for clients to request/register tokens
ENROLL_SECRET=

# Admin secret for /admin approval backend
ADMIN_SECRET=

# Optional site customization
DISPLAY_NAME=Monika
SITE_TITLE=Monika Now
SITE_DESC=What is Monika doing right now?
SITE_FAVICON=/favicon.ico
